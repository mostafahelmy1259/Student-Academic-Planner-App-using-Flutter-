rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, create, update, delete: if request.auth != null
                                          && request.auth.uid == userId;

      match /subjects/{subjectId} {
        allow read, create, update, delete: if request.auth != null
                                            && request.auth.uid == userId;
      }

      match /tasks/{taskId} {
        allow read, create, update, delete: if request.auth != null
                                            && request.auth.uid == userId;
      }

      match /exams/{examId} {
        allow read, create, update, delete: if request.auth != null
                                            && request.auth.uid == userId;
      }
    }
  }
}
